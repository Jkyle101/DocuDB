flowchart LR
    U([User Opens DocuDB]) --> L[Login and RBAC]
    L --> R{Role}

    subgraph Faculty[Faculty]
        direction TB
        F1[Workspace\nMy Drive, Shared, Recent]
        F2[File Management\nUpload, folders, preview, download, rename, move, versions]
        F3[Collaboration\nShare, groups, comments, notifications]
        F4[Smart Tools\nSmart Forms, Editor, Auto Reports]
        F5[COPC Upload\nSubmit evidence, track completeness, revise on request]
        F6([Logout])
        F1 --> F2 --> F3 --> F4 --> F5 --> F6
    end

    subgraph DeptChair[Department Chair]
        direction TB
        D1[Workspace\nDrive, Shared, Recent, Groups]
        D2[Oversight\nMonitor assigned folders and checklist tasks]
        D3[Department Review\nReview submissions, approve/reject, add remarks]
        D4[Forward Stage\nSend approved evidence to QA]
        D5([Logout])
        D1 --> D2 --> D3 --> D4 --> D5
    end

    subgraph QAAdmin[QA Admin]
        direction TB
        Q1[Workspace\nAssigned QA folders and dashboard]
        Q2[QA Compliance Review\nVerify evidence, tag category, add observations]
        Q3[Decision\nApprove/reject and return corrections]
        Q4[Prepare Evaluation\nMark ready items and package inputs]
        Q5([Logout])
        Q1 --> Q2 --> Q3 --> Q4 --> Q5
    end

    subgraph Evaluator[Evaluator]
        direction TB
        E1[Limited Workspace\nShared, Recent, Notifications, COPC Dashboard]
        E2[Evaluation Stage\nOpen approved tree and package]
        E3[Evaluation Actions\nReview evidence and download reports]
        E4([Logout])
        E1 --> E2 --> E3 --> E4
    end

    subgraph Superadmin[Superadmin]
        direction TB
        A1[Admin Console and Admin Drive\nFull system visibility]
        A2[User and Group Management\nCreate bulk/single users, roles, status, group memberships]
        A3[System Governance\nAdmin search, logs, analytics, password request decisions]
        A4[COPC Governance\nInitialize programs, assign roles, manage tasks]
        A5[Finalization\nCompile package, finalize COPC-ready, lock, submit, archive]
        A6[Recovery\nTrash restore and permanent delete]
        A7([Logout])
        A1 --> A2 --> A3 --> A4 --> A5 --> A6 --> A7
    end

    subgraph Core[System Services]
        direction TB
        C1[DocuDB Core\nAPI, auth, workflow engine, search]
        C2[(Database and File Storage)]
        C3[Email Notifications]
        C4[(Backup System)]
        C5[(Audit Logs)]
        C1 <--> C2
        C1 --> C3
        C2 --> C4
        C1 --> C5
    end

    R -->|faculty| F1
    R -->|dept_chair| D1
    R -->|qa_admin| Q1
    R -->|evaluator| E1
    R -->|superadmin| A1

    F1 -.-> C1
    D1 -.-> C1
    Q1 -.-> C1
    E1 -.-> C1
    A1 -.-> C1
