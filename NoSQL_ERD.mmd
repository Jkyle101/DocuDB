erDiagram
    USERS {
        ObjectId _id
        string email
        string password
        string role
        boolean active
        string profilePicture
    }

    FILE {
        ObjectId _id
        string filename
        string originalName
        string mimetype
        number size
        date uploadDate
        date lastAccessedAt
        string userId
        ObjectId owner
        ObjectId parentFolder
        ObjectId[] sharedWith
        string permissions
        date deletedAt
        string[] favoritedBy
        string[] pinnedBy
        string contentHash
        ObjectId duplicateOf
    }

    FILE_CLASSIFICATION {
        string category
        number confidence
        string[] tags
        date classifiedAt
        string classifierVersion
    }

    FILE_REVIEW_WORKFLOW {
        boolean requiresReview
        string status
        ObjectId[] assignedProgramChairs
        ObjectId[] assignedQaOfficers
    }

    FILE_REVIEW_STEP {
        string status
        ObjectId reviewedBy
        date reviewedAt
        string notes
    }

    FILE_VERIFICATION_BADGE {
        boolean verified
        ObjectId verifiedBy
        date verifiedAt
        string label
    }

    FOLDER {
        ObjectId _id
        string name
        ObjectId owner
        ObjectId parentFolder
        boolean isPredefinedRoot
        string predefinedTemplateKey
        ObjectId[] sharedWith
        string permissions
        string complianceProfileKey
        date deletedAt
        date createdAt
    }

