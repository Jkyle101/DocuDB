%%{init: {'theme': 'base', 'flowchart': {'curve': 'linear', 'nodeSpacing': 45, 'rankSpacing': 55}}}%%
flowchart TB
    T["Agile Software Development Project Framework<br/>DOCUDB - WEB-BASED DOCUMENT MANAGEMENT AND COPC WORKFLOW SYSTEM"]

    subgraph REQ["Requirements"]
        direction LR
        FR["FUNCTIONAL REQUIREMENTS<br/>- Authentication and RBAC<br/>- Document, folder, and version management<br/>- Sharing, comments, and notifications<br/>- COPC workflow: upload, review, QA, evaluation<br/>- Search, trash, recovery, and reports"]
        NFR["NON-FUNCTIONAL REQUIREMENTS<br/>- Performance and responsiveness<br/>- Security, privacy, and auditability<br/>- Reliability, backup, and recoverability<br/>- Scalability and maintainability<br/>- Usability and accessibility"]
    end

    subgraph AN["Analysis"]
        direction LR
        A1["Data Requirement Analysis<br/>Users, roles, files, folders, groups"]
        A2["UX and Workflow Analysis<br/>Role journeys and workspace flows"]
        A3["Security and Privacy Analysis<br/>Access matrix and audit requirements"]
        A4["Storage and Metadata Analysis<br/>Schema, lifecycle, retention"]
        A5["Reporting and Monitoring Analysis<br/>KPIs, logs, compliance tracking"]
        A6["Documentation Analysis<br/>Manuals, SOPs, training needs"]
    end

    subgraph DES["Design"]
        direction LR
        D1["Data Model Design<br/>MongoDB schema and indexes"]
        D2["UI and Navigation Design<br/>Role-based dashboards"]
        D3["Auth and Access Design<br/>JWT and RBAC rules"]
        D4["Document Service Design<br/>Upload, share, version, recovery"]
        D5["Dashboard and Report Design<br/>Analytics and COPC status views"]
        D6["Documentation Package Design<br/>Guides and training assets"]
    end

    subgraph IMP["Implementation"]
        direction LR
        I1["Operational Environment<br/>React + Vite | Node.js + Express | MongoDB<br/>File storage, email service, audit logging<br/>Docker/PM2/Nginx setup"]
    end

    subgraph TST["Testing"]
        direction LR
        T1["Quality Validation (ISO/IEC 25010)<br/>Functional suitability, reliability, performance efficiency, security,<br/>compatibility, maintainability, and usability"]
        T2["User Testing<br/>Role-based UAT and COPC scenario validation"]
    end

    subgraph DEP["Deployment"]
        direction LR
        P1["System Deployment<br/>Build and release, DB init/migration,<br/>backup activation, monitoring, and security hardening"]
    end

    subgraph REV["Review"]
        direction LR
        R1["Feedback and Continuous Improvement<br/>Collect feedback, evaluate outcomes, prioritize fixes"]
    end

    T --> FR
    T --> NFR

    FR --> A1
    NFR --> A1
    A1 --> A2 --> A3 --> A4 --> A5 --> A6

    A6 --> D1
    D1 --> D2 --> D3 --> D4 --> D5 --> D6
    D6 --> I1

    I1 --> T1
    I1 --> T2
    T1 --> P1
    T2 --> P1
    P1 --> R1
    R1 -. Feedback loop .-> A2

    classDef title fill:#f8f8f8,stroke:#3a3a3a,stroke-width:1.2px,color:#111,font-size:14px,font-weight:bold;
    classDef req fill:#e3e3e3,stroke:#666,color:#111,font-size:12px;
    classDef analysis fill:#f7efe1,stroke:#8d6f4c,color:#111,font-size:11px;
    classDef design fill:#dce9f7,stroke:#4d6d8a,color:#111,font-size:11px;
    classDef impl fill:#e8edf3,stroke:#5b6f86,color:#111,font-size:12px;
    classDef test fill:#eef4ea,stroke:#5d7f50,color:#111,font-size:11px;
    classDef deploy fill:#f5f0e6,stroke:#8a744f,color:#111,font-size:12px;
    classDef review fill:#ececec,stroke:#666,color:#111,font-size:12px;

    class T title;
    class FR,NFR req;
    class A1,A2,A3,A4,A5,A6 analysis;
    class D1,D2,D3,D4,D5,D6 design;
    class I1 impl;
    class T1,T2 test;
    class P1 deploy;
    class R1 review;

    style REQ fill:transparent,stroke:transparent
    style AN fill:transparent,stroke:transparent
    style DES fill:transparent,stroke:transparent
    style IMP fill:transparent,stroke:transparent
    style TST fill:transparent,stroke:transparent
    style DEP fill:transparent,stroke:transparent
    style REV fill:transparent,stroke:transparent
