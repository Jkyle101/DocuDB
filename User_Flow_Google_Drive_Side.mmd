flowchart TD
    start([User opens DocuDB]) --> login[Login]
    login --> role{Role?}

    subgraph Faculty_Flow[Faculty User Flow]
        F1[Open My Drive]
        F2[Browse folders and files]
        F3[Upload file or create folder]
        F4[Preview, download, rename, move,\nfavorite, or pin file]
        F5[Share file or folder with users]
        F6[Open comments and collaborate]
        F7[Check Shared with Me, Recent,\nGroups, Notifications, Settings]
        F8[Use Smart Forms / Editor]
        F9[Respond to document requests]
        F10[Logout]
        F1 --> F2 --> F3 --> F4 --> F5 --> F6 --> F7 --> F8 --> F9 --> F10
    end

    subgraph Dept_Chair_Flow[Department Chair Flow]
        D1[Open My Drive]
        D2[Review assigned folders and tasks]
        D3[Upload and organize department files]
        D4[Review shared content and comments]
        D5[Request missing documents from faculty]
        D6[Access collaboration modules:\nGroups, Shared, Recent, Notifications]
        D7[Proceed to COPC review when needed]
        D8[Logout]
        D1 --> D2 --> D3 --> D4 --> D5 --> D6 --> D7 --> D8
    end

    subgraph QA_Flow[QA Admin Flow]
        Q1[Open My Drive]
        Q2[Access assigned QA folders and checklists]
        Q3[Review uploaded files and verification status]
        Q4[Manage task progress and compliance widgets]
        Q5[Share, comment, preview, and restore files if needed]
        Q6[Open notifications and group collaboration tools]
        Q7[Proceed to QA compliance review workflow]
        Q8[Logout]
        Q1 --> Q2 --> Q3 --> Q4 --> Q5 --> Q6 --> Q7 --> Q8
    end

    subgraph Evaluator_Flow[Evaluator Flow]
        E1[Login to user workspace]
        E2[Access Shared, Recent,\nNotifications, and COPC entry points]
        E3[Preview and download allowed documents]
        E4[Review final materials for evaluation]
        E5[Logout]
        E1 --> E2 --> E3 --> E4 --> E5
    end

    subgraph Superadmin_Flow[Superadmin Drive and Admin Flow]
        A1[Open Admin Workspace]
        A2[Manage Users]
        A3[Manage Groups]
        A4[Manage Tasks and Assignments]
        A5[Open Admin Drive / Admin Workspace]
        A6[View logs, analytics,\nand trash management]
        A7[Access COPC program management]
        A8[Logout]
        A1 --> A2 --> A3 --> A4 --> A5 --> A6 --> A7 --> A8
    end

    role -->|faculty| F1
    role -->|dept_chair| D1
    role -->|qa_admin| Q1
    role -->|evaluator| E1
    role -->|superadmin| A1
