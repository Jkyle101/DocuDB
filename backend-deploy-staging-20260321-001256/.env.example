# Network
PORT=3001
HOST=0.0.0.0

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.hewognp.mongodb.net/docudb?retryWrites=true&w=majority&appName=Cluster0

# Frontend + CORS
FRONTEND_URL=https://docudb.site
CORS_ORIGINS=https://docudb.site,https://www.docudb.site
CORS_ALLOW_LAN=false
# CORS_ORIGIN=https://docudb.site

# Auth policy
MIN_PASSWORD_LENGTH=8
ALLOWED_EMAIL_DOMAIN=llcc.edu.ph
AUTH_CODE_LENGTH=6
AUTH_CODE_MAX_ATTEMPTS=5
REGISTER_OTP_EXP_MINUTES=10
LOGIN_OTP_EXP_MINUTES=10
RESET_OTP_EXP_MINUTES=10

# SMTP (optional)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@docudb.site
SMTP_PASS=<smtp_password>
SMTP_FROM_NAME=DocuDB
