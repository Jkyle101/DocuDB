flowchart TD
    start([User opens COPC Workflow]) --> login[Login]
    login --> role{Role?}

    subgraph Faculty_COPC[Faculty COPC Flow]
        CF1[Open COPC Workflow or COPC Upload]
        CF2[Select assigned program]
        CF3[Open assigned COPC folders]
        CF4[Upload required documents]
        CF5[Check completeness and task status]
        CF6[Revise files if rejected or requested]
        CF7[Track notification and submission status]
        CF8[Wait for department and QA review]
        CF1 --> CF2 --> CF3 --> CF4 --> CF5 --> CF6 --> CF7 --> CF8
    end

    subgraph Dept_COPC[Department Chair COPC Flow]
        CD1[Open COPC Workflow]
        CD2[Select program]
        CD3[Monitor faculty submission status]
        CD4[Open Department Review page]
        CD5[Review submissions against checklist]
        CD6[Approve or reject documents]
        CD7[Add notes and send back for revision if needed]
        CD8[Forward approved submissions to QA stage]
        CD1 --> CD2 --> CD3 --> CD4 --> CD5 --> CD6 --> CD7 --> CD8
    end

    subgraph QA_COPC[QA Admin COPC Flow]
        CQ1[Open COPC Workflow]
        CQ2[Select program]
        CQ3[Review compliance summary and pending QA items]
        CQ4[Open QA Review page]
        CQ5[Tag category and verify compliance]
        CQ6[Approve or reject documents]
        CQ7[Add observations and internal evaluation flags]
        CQ8[Prepare program for package compilation]
        CQ1 --> CQ2 --> CQ3 --> CQ4 --> CQ5 --> CQ6 --> CQ7 --> CQ8
    end

    subgraph Evaluator_COPC[Evaluator COPC Flow]
        CE1[Open Evaluation Stage]
        CE2[Select assigned program]
        CE3[Access approved tree and package]
        CE4[Preview and download evaluation materials]
        CE5[Review compliance evidence]
        CE6[Generate or download evaluation report]
        CE1 --> CE2 --> CE3 --> CE4 --> CE5 --> CE6
    end

    subgraph Admin_COPC[Superadmin COPC Flow]
        CA1[Open COPC Workflow]
        CA2[Initialize COPC program structure]
        CA3[Assign uploaders, dept chairs,\nQA admins, and evaluators]
        CA4[Monitor workflow stage and summary cards]
        CA5[Open package and download ZIP]
        CA6[Compile COPC package]
        CA7[Finalize COPC Ready and lock documents]
        CA8[Submit to CHED]
        CA9[Archive completed program]
        CA1 --> CA2 --> CA3 --> CA4 --> CA5 --> CA6 --> CA7 --> CA8 --> CA9
    end

    role -->|faculty| CF1
    role -->|dept_chair| CD1
    role -->|qa_admin| CQ1
    role -->|evaluator| CE1
    role -->|superadmin| CA1
